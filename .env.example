# ─────────────────────────────────────────────────────────────────────────────
# Environment configuration template — IoT Network Intrusion Detection
#
# HOW TO USE
#   1. Copy this file to `.env`:            cp .env.example .env
#   2. Fill in the values below. For LLM features, set APP_LLM_PROVIDER and
#      the matching key (GEMINI_API_KEY or ANTHROPIC_API_KEY).
#   3. Load it into your shell before running the app — Spring Boot does NOT
#      read `.env` automatically:
#        set -a; source .env; set +a
#        ./mvnw spring-boot:run
#
# `.env` is gitignored — never commit it or any real secret. THIS file
# (`.env.example`) is the committed template; keep it free of real values.
#
# These are consumed as Spring "relaxed binding" environment variables
# (APP_LLM_ENABLED -> app.llm.enabled). Every value below already matches the
# application.yml / docker-compose defaults, so you only need to set what you
# actually want to override.
# ─────────────────────────────────────────────────────────────────────────────

# ===== LLM features (enrichment + /api/chat) =====
# Which provider powers the LLM features. Default "groq" (free, no credit card).
# Valid values: groq | gemini | anthropic. Set the matching API key below.
APP_LLM_PROVIDER=groq

# Master switch for all LLM features. Default false: the app starts cleanly
# with no API key. Set to true (and provide the selected provider's key) to enable.
APP_LLM_ENABLED=false

# API keys — read directly from the environment (not Spring properties), so they
# MUST be exported into the shell that runs the app. Only the key for the selected
# APP_LLM_PROVIDER is needed; leave the other blank.
#   Groq    -> https://console.groq.com  (free, no credit card, no region limit)
#   Gemini  -> https://aistudio.google.com  (free tier; not available in all regions)
#   Anthropic (paid Developer Platform) -> https://console.anthropic.com
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Per-provider model ids.
APP_LLM_GROQ_MODEL=llama-3.3-70b-versatile
APP_LLM_GEMINI_MODEL=gemini-2.0-flash
APP_LLM_ANTHROPIC_MODEL=claude-haiku-4-5

# Per-call request timeout.
APP_LLM_TIMEOUT=30s
# Number of unenriched alerts processed per scheduler tick.
APP_LLM_ENRICHMENT_BATCH_SIZE=10
# Delay between enrichment sweeps.
APP_LLM_ENRICHMENT_POLL_INTERVAL=10s

# ===== Database (PostgreSQL) =====
# Defaults match the bundled docker-compose postgres service.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/iot_ids
SPRING_DATASOURCE_USERNAME=iot
SPRING_DATASOURCE_PASSWORD=iot

# ===== Kafka =====
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===== ML detection service =====
APP_ML_ENABLED=true
APP_ML_URL=http://localhost:8000

# ===== Traffic simulator (CSV replay) =====
APP_SIMULATOR_ENABLED=false
APP_SIMULATOR_CSV_PATH=data/RT_IOT2022.csv
